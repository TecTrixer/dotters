[init]
defaultBranch = main

[gpg]
format = "ssh"

[commit]
gpgsign = true

[user]
name = "TecTrixer"
email = "tonihoevedes@gmail.com"
signingkey = "/home/constantin/.ssh/id_ed25519"

[core]
	pager = delta
[delta]
	side-by-side = true
	line-numbers = false
	file-style = omit
	hunk-header-style = omit

[alias]
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ar) %C(bold blue)<%an>%Creset' --abbrev-commit --all
